# Copy this file to .env and fill in your values (or set these directly as
# Environment variables in the Portainer Stack UI instead of using a file).

# xiaozhi WebSocket endpoint this bridge connects to. Required.
MCP_ENDPOINT=

# JMRI Web Server URL, reachable from wherever this container runs.
JMRI_URL=http://localhost:12080

# Optional: see docs/exhibition.md for what these do.
EXHIBITION_PASSWORD=
EXHIBITION_ALLOWED_ADDRESSES=
EXHIBITION_START_ON=
